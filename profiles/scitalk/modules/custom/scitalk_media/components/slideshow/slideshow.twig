<div class="talk-slider-container">
    <ul class="controls" id="customize-controls" aria-label="Carousel Navigation" tabindex="0">
        <li class="prev" data-controls="prev" aria-controls="customize" tabindex="-1">
            <i class="fas fa-angle-left fa-3x"></i>
        </li>
        <li class="next" data-controls="next" aria-controls="customize" tabindex="-1">
            <i class="fas fa-angle-right fa-3x"></i>
        </li>
    </ul>
    <div class="talk-slider">
        {% set slides_cnt = slide_images|length %}
        {% for key, slide in slide_images %}
            {% set slide_number = key + 1 %}
            <div class="talk-slider-item">
                <div class="talk-slider-card">
                    <img class="tns-lazy-img" data-src="{{ slide }}" loading="lazy" src="{{ slide }}" alt="Slide {{ slide_number }}/{{ slides_cnt }}"/>
                    {# <img width="100" height="100" loading="lazy" src="{{ slide }}" alt="{{ slide }}"/> #}
                    <h3>Slide {{slide_number }}</h3>
                    {# <p class="talk-slider-card_description">pirsa test</p> #}
                </div>
            </div>
        {% endfor %}
    </div>    
</div>

<div id="slides-modal" class="modal" draggable="false">
    <span class="slides-modal-close">&times;</span>
    <div class="slides-modal-body">
        <ul class="controls" id="customize-modal-controls" aria-label="Modal Navigation" tabindex="0">
            <li class="prev" data-controls="prev" aria-controls="tns2" tabindex="-1" aria-disabled="true">
                <i class="fas fa-angle-left fa-2x"></i>
            </li>
            <li class="next" data-controls="next" aria-controls="tns2" tabindex="-1">
                <i class="fas fa-angle-right fa-2x"></i>
            </li>
        </ul>

        <img class="modal-content" id="slides-modal-content">
        <div id="slides-modal-caption"></div>
  </div>
</div>
