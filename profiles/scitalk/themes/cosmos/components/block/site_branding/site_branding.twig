<div {{ attributes.addClass('site-branding') }}>
  {% if site_logo %}
    <a href="{{ path('<front>') }}" title="{{ 'Home'|t }}" rel="home">
      <img src="{{ site_logo }}" alt="{{ 'Home'|t }}" />
    </a>
  {% endif %}
  {% if site_name %}
    <a href="{{ path('<front>') }}" title="{{ 'Home'|t }}" rel="home" class="site-name">
      {{ site_name }}
    </a>
  {% endif %}
  {% if site_slogan %}
    <p class="site-slogan">{{ site_slogan }}</p>
  {% endif %}
</div>
