{#
/**
 * @file
 * Theme override to display a menu.
 *
 * Available variables:
 * - menu_name: The machine name of the menu.
 * - items: A nested list of menu items. Each menu item contains:
 *   - attributes: HTML attributes for the menu item.
 *   - below: The menu item child items.
 *   - title: The menu link title.
 *   - url: The menu link URL, instance of \Drupal\Core\Url
 *   - localized_options: Menu link localized options.
 *   - is_expanded: TRUE if the link has visible children within the current
 *     menu tree.
 *   - is_collapsed: TRUE if the link has children within the current menu tree
 *     that are not currently visible.
 *   - in_active_trail: TRUE if the link is in the active trail.
 */
#}
{% import _self as menus %}

{#
  We call a macro which calls itself to render the full tree.
#}

{% set classes = [
  'menu',
  'menu--' ~ menu_name
] %}

{% for modifier in modifiers %}
  {% set classes = classes|merge(["menu--" ~ modifier]) %}
{% endfor %}
{% set attributes = attributes.addClass(classes) %}
{{ menus.menu_links(menu_items, attributes, 0, show_triggers, menu_name) }}

{% macro menu_links(menu_items, attributes, menu_level, show_triggers, menu_name) %}
  {% import _self as menus %}

  {% set menu_id = 'menu--' ~ menu_name|clean_class ~ '--' ~ menu_level %}

  {% if menu_items %}
    {% if menu_level == 0 %}
      <ul{{ attributes.addClass(classes, ['menu-level--' ~ menu_level]) }}>
    {% else %}
      <ul class="menu menu-level--{{menu_level}}">
    {% endif %}
    {% for item in menu_items %}
      {%
        set classes = [
          'menu-item',
          item.is_expanded ? 'menu-item--expanded',
          item.is_collapsed ? 'menu-item--collapsed',
          item.in_active_trail ? 'menu-item--active-trail',
        ]
      %}
      <li{{ item.attributes.addClass(classes) }}>
        {{ link(item.title, item.url, {class: ['menu-link'] }) }}

        {% if show_triggers == TRUE and item.is_expanded and menu_level == 0 %}
          <button class="menu-dropdown-trigger button-unstyled" aria-expanded="false" aria-controls="{{ menu_id }} ">
            <span class="hidden">{{ '@title sub-menu'|t({'@title': item.title}) }}</span>
             {{ include("cosmos:icon", {icon_name: 'chevron-down' })}}
          </button>
        {% endif %}

        {% if item.below %}
          {{ menus.menu_links(item.below, attributes, menu_level + 1, show_triggers, menu_name) }}
        {% endif %}

      </li>
    {% endfor %}
    </ul>
  {% endif %}
{% endmacro %}
